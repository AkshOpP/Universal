-- CONTENT
local content = Instance.new("Frame", main)
content.Position = UDim2.fromScale(0.24,0.12)
content.Size = UDim2.fromScale(0.76,0.88)

local pages = Instance.new("Folder", content)

local function createPage(name)
	local s = Instance.new("ScrollingFrame", pages)
	s.Name = name
	s.Size = UDim2.fromScale(1,1)
	s.Visible = false
	s.AutomaticCanvasSize = Enum.AutomaticSize.Y
	local l = Instance.new("UIListLayout", s)
	l.Padding = UDim.new(0,10)
	return s
end

local function createTab(name,page)
	local b = Instance.new("TextButton", sidebar)
	b.Size = UDim2.fromScale(1,0.12)
	b.Text = name
	b.MouseButton1Click:Connect(function()
		for _,p in pairs(pages:GetChildren()) do p.Visible=false end
		page.Visible=true
	end)
end

local function button(p,t,cb)
	local b=Instance.new("TextButton",p)
	b.Size=UDim2.fromScale(1,0.13)
	b.Text=t
	b.MouseButton1Click:Connect(cb)
end

