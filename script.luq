end)

button(movePage,"Fly",function()
	loadstring(game:HttpGet("https://raw.githubusercontent.com/XNEOFF/FlyGuiV3/main/FlyGuiV3.txt"))()
end)

-- TP
local saved={nil,nil,nil}
for i=1,3 do
	button(tpPage,"Save "..i,function() saved[i]=hrp().CFrame end)
	button(tpPage,"TP "..i,function() if saved[i] then hrp().CFrame=saved[i] end end)
end

-- SPECTATE SYSTEM (TP TAB)

local spectating = false
local specList = {}
local specIndex = 1

local function updateSpec()
	specList = {}
	for _,p in pairs(Players:GetPlayers()) do
		if p ~= player then
			table.insert(specList, p)
		end
	end
end

local function applySpec()
	local target = specList[specIndex]
	if target and target.Character then
		local hum = target.Character:FindFirstChild("Humanoid")
		if hum then
			workspace.CurrentCamera.CameraSubject = hum
		end
	end
end

local function getSpecInfo()
	local target = specList[specIndex]
	if not target or not target.Character then
		return "None",0,0
	end
	
	local hum = target.Character:FindFirstChild("Humanoid")
	local root = target.Character:FindFirstChild("HumanoidRootPart")
	local myRoot = hrp()
	
	local hp = hum and math.floor(hum.Health) or 0
	local dist = 0
	
	if root and myRoot then
		dist = math.floor((root.Position - myRoot.Position).Magnitude)
	end
	
	return target.Name,hp,dist
end

-- Toggle
button(tpPage,"Spectate",function()
	spectating = not spectating
	
	if spectating then
		updateSpec()
		specIndex = 1
		applySpec()
	else
		if player.Character then
			workspace.CurrentCamera.CameraSubject = hum()
		end
	end
end)

-- Next →
button(tpPage,"Next Player",function()
	if not spectating then return end
	specIndex += 1
	if specIndex > #specList then specIndex = 1 end
	applySpec()
end)

-- Previous ←
button(tpPage,"Previous Player",function()
	if not spectating then return end
	specIndex -= 1
	if specIndex < 1 then specIndex = #specList end
	applySpec()
end)

-- INFO LOOP (prints in console, you can later link to label)
task.spawn(function()
	while true do
		task.wait(0.5)
		if spectating then
			local name,hp,dist = getSpecInfo()
			print("Watching:",name,"HP:",hp,"Dist:",dist)
		end
	end
end)

-- VISUAL
button(visPage," ADVANCED ESP",function()
	for _,p in pairs(Players:GetPlayers()) do
		if p~=player and p.Character then
			local h=Instance.new("Highlight",p.Character)
		end
	end
end)

-- COMBAT
local aim=false
button(combatPage,"Aim Assist",function() aim=not aim end)

RS.RenderStepped:Connect(function()
	if aim then
		local c,d=nil,9999
		for _,p in pairs(Players:GetPlayers()) do
			if p~=player and p.Character and p.Character:FindFirstChild("Head") then
				local dist=(p.Character.Head.Position-hrp().Position).Magnitude
				if dist<d then d=dist c=p end
			end
		end
		if c then
			workspace.CurrentCamera.CFrame=CFrame.new(workspace.CurrentCamera.CFrame.Position,c.Character.Head.Position)
		end
	end
end)

local aura=false
button(combatPage,"Kill Aura",function() aura=not aura end)

RS.Heartbeat:Connect(function()
	if aura then
		for _,p in pairs(Players:GetPlayers()) do
			if p~=player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				firetouchinterest(hrp(),p.Character.HumanoidRootPart,0)
				firetouchinterest(hrp(),p.Character.HumanoidRootPart,1)
			end
		end
	end
end)

